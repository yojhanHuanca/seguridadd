# Dependencies
.pnpm-store
# Build output
dist
dist-ssr
*.local
# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# TS build artifacts
*.tsbuildinfo
tempo/.tempo/
tempo/dist/

# node_modules trees are COMMITTED (prebaked FTUE deps) — re-include content
# that the generic patterns above (dist, logs, *.log, …) would otherwise match.
!node_modules/**
# …except runtime caches vite writes on boot:
node_modules/.vite/
node_modules/.cache/
