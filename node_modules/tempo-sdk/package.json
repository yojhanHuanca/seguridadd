{
  "name": "tempo-sdk",
  "version": "0.0.18",
  "type": "module",
  "description": "Tempo SDK — Vite, Next.js, and Expo plugins for JSX annotation and shared page/storyboard types",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    },
    "./canvas/parser": {
      "types": "./dist/canvas/parser.d.ts",
      "import": "./dist/canvas/parser.js"
    },
    "./canvas/editor": {
      "types": "./dist/canvas/editor.d.ts",
      "import": "./dist/canvas/editor.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs"
    },
    "./nextjs/plugin": {
      "types": "./dist/nextjs/plugin.d.ts",
      "import": "./dist/nextjs/plugin.js"
    },
    "./expo": {
      "types": "./dist/expo-babel-plugin.d.ts",
      "import": "./dist/expo-babel-plugin.js",
      "require": "./dist/expo-babel-plugin.cjs"
    },
    "./expo/plugin": {
      "types": "./dist/expo/plugin.d.ts",
      "import": "./dist/expo/plugin.js",
      "require": "./dist/expo/plugin.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@rollup/pluginutils": "^5.1.0",
    "oxc-parser": "^0.110.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0",
    "next": "^13 || ^14 || ^15 || ^16",
    "react": "^18 || ^19",
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "playwright-core": "^1.58.2",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "@modules/annotation": "0.0.1",
    "@modules/file-parser": "0.0.1"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsup",
    "build:if-missing": "test -f dist/index.js || pnpm run build",
    "demo": "TEMPO=true pnpm --filter @tempo-modules/vite-annotate-plugin-demo dev",
    "demo:nextjs": "TEMPO=true pnpm --filter @tempo-modules/tempo-sdk-nextjs-demo dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:nextjs:unit": "vitest run nextjs-loader.test.ts nextjs-wrapper.test.ts nextjs-fixtures.test.ts nextjs-published.test.ts",
    "test:nextjs:integration": "vitest run nextjs-e2e-correctness.test.ts",
    "test:nextjs:production": "vitest run nextjs-production.test.ts",
    "test:nextjs": "vitest run nextjs-loader.test.ts nextjs-wrapper.test.ts nextjs-fixtures.test.ts nextjs-published.test.ts nextjs-e2e-correctness.test.ts nextjs-production.test.ts"
  }
}